---
import Base from "../layouts/Base.astro";
import { TEMAS } from "../lib/temas";

// Static class maps - Tailwind purga clases dinamicas, asi que las listamos aqui.
const gradients: Record<string, string> = {
  indigo: "from-indigo-500 to-indigo-600",
  violet: "from-violet-500 to-violet-600",
  pink: "from-pink-500 to-pink-600",
  cyan: "from-cyan-500 to-cyan-600",
  amber: "from-amber-500 to-amber-600",
  emerald: "from-emerald-500 to-emerald-600",
  rose: "from-rose-500 to-rose-600",
  sky: "from-sky-500 to-sky-600",
};
const bgTints: Record<string, string> = {
  indigo: "hover:bg-indigo-50/40",
  violet: "hover:bg-violet-50/40",
  pink: "hover:bg-pink-50/40",
  cyan: "hover:bg-cyan-50/40",
  amber: "hover:bg-amber-50/40",
  emerald: "hover:bg-emerald-50/40",
  rose: "hover:bg-rose-50/40",
  sky: "hover:bg-sky-50/40",
};

const upcoming = [
  {
    nombre: "Educación",
    tagline: "Cobertura, calidad y abandono escolar — desde primera infancia hasta posgrado",
    icono: "🎓",
    color: "amber" as const,
  },
  {
    nombre: "Seguridad",
    tagline: "Violencia, percepción de seguridad y dinámicas territoriales",
    icono: "🛡️",
    color: "rose" as const,
  },
  {
    nombre: "Salud",
    tagline: "Acceso, cobertura, brechas regionales y resultados",
    icono: "🩺",
    color: "emerald" as const,
  },
];
---

<Base title="Entendiendo Colombia">
  <!-- HERO -->
  <section class="relative overflow-hidden mesh-gradient-hero">
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 pt-12 pb-16 sm:pt-16 sm:pb-20 md:pt-28 md:pb-32">
      <div class="flex justify-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white/80 px-3 sm:px-4 py-1.5 text-[11px] sm:text-xs font-medium text-indigo-700 shadow-sm backdrop-blur text-center">
          <span class="flex h-1.5 w-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>
          Datos abiertos · Metodología transparente · Sin jerga
        </div>
      </div>

      <h1 class="mt-6 sm:mt-8 text-center text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.05] text-neutral-900">
        Entendiendo<br />
        <span class="gradient-text">Colombia</span>
      </h1>

      <p class="mx-auto mt-5 sm:mt-6 max-w-2xl text-center text-base sm:text-lg md:text-xl text-neutral-600 leading-relaxed px-2">
        Análisis temáticos de los grandes problemas del país. Cada tema es un
        recorrido paso a paso con datos oficiales y gráficas interactivas.
      </p>

      <div class="mt-8 sm:mt-10 flex justify-center px-4 sm:px-0">
        <a href="#temas" class="btn-primary justify-center">
          Ver los temas
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
    <div class="absolute inset-x-0 bottom-0 h-24 sm:h-32 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <!-- TEMAS -->
  <section id="temas" class="relative mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20 md:py-24">
    <div class="text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-neutral-500">
        Temas
      </div>
      <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-neutral-900">
        Por dónde empezar
      </h2>
      <p class="mt-4 text-base sm:text-lg text-neutral-600 max-w-2xl mx-auto">
        Empezamos con empleo. Vamos sumando temas con la misma metodología:
        datos abiertos, fuentes verificables, explicaciones claras.
      </p>
    </div>

    <div class="mt-10 sm:mt-12 md:mt-14 grid gap-5 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {TEMAS.map((t) => (
        <a
          href={`/temas/${t.slug}`}
          class:list={[
            "group relative flex flex-col gap-4 rounded-2xl border border-neutral-200 bg-white p-6 sm:p-7 transition-all",
            "hover:border-neutral-300 hover:shadow-lg hover:-translate-y-1 cursor-pointer",
            bgTints[t.color],
          ]}
        >
          <div class="flex items-start justify-between gap-4">
            <div class:list={[
              "flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br shadow-sm",
              gradients[t.color],
            ]}>
              <span class="text-2xl">{t.icono}</span>
            </div>
            <div class="text-xs font-mono font-semibold uppercase tracking-wider text-neutral-400">
              {t.capitulos.length} caps
            </div>
          </div>
          <div>
            <h3 class="text-xl font-bold text-neutral-900 leading-snug">{t.nombre}</h3>
            <p class="mt-2 text-sm text-neutral-600 leading-relaxed">{t.tagline}</p>
          </div>
          <div class="flex items-center gap-1 text-sm font-semibold text-indigo-600 group-hover:gap-2 transition-all">
            Explorar tema
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>
        </a>
      ))}

      {upcoming.map((t) => (
        <div class="relative flex flex-col gap-4 rounded-2xl border border-dashed border-neutral-200 bg-neutral-50/50 p-6 sm:p-7 opacity-70">
          <div class="flex items-start justify-between gap-4">
            <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-neutral-200">
              <span class="text-2xl grayscale">{t.icono}</span>
            </div>
            <div class="text-xs font-mono font-semibold uppercase tracking-wider text-neutral-400">
              Pronto
            </div>
          </div>
          <div>
            <h3 class="text-xl font-bold text-neutral-700 leading-snug">{t.nombre}</h3>
            <p class="mt-2 text-sm text-neutral-500 leading-relaxed">{t.tagline}</p>
          </div>
          <div class="text-xs font-semibold uppercase tracking-wider text-neutral-400">
            En investigación
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- METODOLOGIA / QUE HACE DIFERENTE -->
  <section class="bg-neutral-50 border-y border-neutral-200">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20 md:py-24">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-neutral-500">
          Cómo trabajamos
        </div>
        <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-neutral-900">
          Tres principios<br class="hidden sm:inline" />
          <span class="gradient-text-subtle">para cada análisis</span>
        </h2>
      </div>

      <div class="mt-10 sm:mt-12 md:mt-16 grid gap-5 sm:gap-6 md:grid-cols-3">
        <div class="card">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-50">
            <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-neutral-900">Fuentes oficiales</h3>
          <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
            DANE, UGPP, Banco de la República, ministerios. Cada cifra tiene su
            link directo a la fuente primaria, sin intermediarios.
          </p>
        </div>

        <div class="card">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-violet-50">
            <svg class="h-5 w-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-neutral-900">Gráficas interactivas</h3>
          <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
            Cada dato tiene su gráfica. Pasa el mouse, filtra, explora. Los datos
            hablan más cuando los puedes tocar.
          </p>
        </div>

        <div class="card">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-pink-50">
            <svg class="h-5 w-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-neutral-900">Metodología transparente</h3>
          <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
            Te explicamos cómo se mide cada cosa, por qué algunas fuentes se
            contradicen, y cómo verificarlo tú mismo.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
