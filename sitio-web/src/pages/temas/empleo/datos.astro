---
import Base from "../../../layouts/Base.astro";

const datasets = [
  {
    name: "Serie mensual GEIH - Total nacional 2001-2026",
    file: "geih_total_nacional_mensual_2001_2026.csv",
    description: "296 meses de indicadores de mercado laboral: PET, PEA, PEI, ocupados, desocupados, tasas.",
    source: "DANE - GEIH",
  },
  {
    name: "Serie mensual GEIH - 13 ciudades 2001-2026",
    file: "geih_13_ciudades_mensual_2001_2026.csv",
    description: "Misma serie que la anterior pero para el agregado de las 13 ciudades principales.",
    source: "DANE - GEIH",
  },
  {
    name: "Ocupados por rama de actividad 2015-2026",
    file: "ocupados_por_rama_nacional_2015_2026.csv",
    description: "133 meses de empleo por sector economico (agricultura, comercio, gobierno, etc).",
    source: "DANE - GEIH",
  },
  {
    name: "Ocupados por posicion ocupacional 2010-2026",
    file: "ocupados_por_posicion_nacional_2010_2026.csv",
    description: "Trabajadores por tipo: empleado particular, cuenta propia, patron, domestico, jornalero.",
    source: "DANE - GEIH",
  },
  {
    name: "PEI desagregada 2010-2026",
    file: "pei_desagregada_nacional_2010_2026.csv",
    description: "Poblacion fuera de la fuerza de trabajo: oficios del hogar, estudiando, otros.",
    source: "DANE - GEIH",
  },
  {
    name: "Informalidad por ciudad (trimestral) 2021-2025",
    file: "informalidad_por_ciudad_trimestre_movil_2021_2025.csv",
    description: "57 trimestres de tasa de informalidad en 26 dominios (nacional, 13 ciudades, 23 ciudades individuales).",
    source: "DANE - GEIH Ocupacion Informal",
  },
  {
    name: "Informalidad por sexo 2021-2025",
    file: "informalidad_por_sexo_trimestre_movil_2021_2025.csv",
    description: "Ocupados formales e informales desagregados por sexo (hombres/mujeres).",
    source: "DANE - GEIH",
  },
  {
    name: "Informalidad por tamano de empresa 2021-2025",
    file: "informalidad_por_tamano_empresa_2021_2025.csv",
    description: "Formalidad segmentada por tamano: micro, pequena, mediana, grande.",
    source: "DANE - GEIH",
  },
  {
    name: "Poblacion Colombia 2018-2070",
    file: "poblacion_colombia_2018_2070.csv",
    description: "Proyecciones oficiales de poblacion total, urbana y rural. Incluye el pico en 2050.",
    source: "DANE - Proyecciones",
  },
  {
    name: "Piramide poblacional 2026",
    file: "piramide_poblacional_2026.csv",
    description: "Poblacion por edad (0 a 100+ anos) desagregada por sexo.",
    source: "DANE - Proyecciones por sexo y edad",
  },
  {
    name: "Piramide poblacional consolidada (5 anios clave)",
    file: "piramide_poblacional_consolidada.csv",
    description: "2020, 2023, 2026, 2030 y 2050 en una sola tabla para comparaciones.",
    source: "DANE - Proyecciones por sexo y edad",
  },
  {
    name: "Nacimientos y defunciones 2015-2024",
    file: "nacimientos_defunciones_2015_2024.csv",
    description: "Serie anual de nacimientos y muertes en Colombia. Muestra la caida del 31.3% en natalidad.",
    source: "DANE - Estadisticas Vitales",
  },
];
---

<Base title="Datos">
  <section class="border-b border-neutral-200 mesh-gradient-hero">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 py-12 sm:py-16 md:py-20 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white/80 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-indigo-700 backdrop-blur">
        Datos abiertos
      </div>
      <h1 class="mt-5 text-4xl sm:text-5xl font-extrabold tracking-tighter text-neutral-900">
        Descarga los datos
      </h1>
      <p class="mt-4 text-base sm:text-lg text-neutral-600 max-w-2xl mx-auto">
        Todos los datos que usamos en este sitio están disponibles para descarga.
        Son los mismos archivos del DANE, limpiados y convertidos a CSV.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid gap-4">
      {datasets.map((d) => (
        <div class="group rounded-xl border border-neutral-200 bg-white p-4 sm:p-5 hover:border-indigo-300 hover:shadow-sm transition-all">
          <div class="flex items-start justify-between gap-3 sm:gap-4">
            <div class="flex-1 min-w-0">
              <h3 class="text-sm sm:text-base font-bold text-neutral-900">{d.name}</h3>
              <p class="mt-1.5 text-xs sm:text-sm text-neutral-600 leading-relaxed">{d.description}</p>
              <div class="mt-3 flex items-center gap-2 text-xs text-neutral-500 flex-wrap">
                <span class="font-mono bg-neutral-100 px-2 py-0.5 rounded text-[10px] sm:text-xs break-all">{d.file}</span>
                <span class="hidden sm:inline">·</span>
                <span>{d.source}</span>
              </div>
            </div>
            <a
              href={`/data/empleo/${d.file}`}
              download
              class="flex-shrink-0 inline-flex items-center gap-1.5 rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 text-xs font-semibold text-neutral-700 group-hover:border-indigo-300 group-hover:bg-indigo-50 group-hover:text-indigo-700 transition-colors"
            >
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              CSV
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50/60 to-violet-50/40 p-5 sm:p-6">
      <h3 class="text-base font-bold text-neutral-900">Cómo citar estos datos</h3>
      <p class="mt-2 text-sm text-neutral-700">
        Los datos son propiedad de sus fuentes originales (principalmente DANE). Si los usas
        en un trabajo, cita la fuente oficial directamente. El DANE los pone a disposición
        pública en <a href="https://www.dane.gov.co" class="text-indigo-600 font-semibold" target="_blank" rel="noopener">dane.gov.co</a>.
      </p>
      <p class="mt-2 text-sm text-neutral-700">
        Si usas el trabajo de consolidación de este sitio, puedes citarlo como:
        "Entendiendo Colombia — Tema Empleo (2026). Datasets consolidados del mercado laboral colombiano."
      </p>
    </div>
  </section>
</Base>
