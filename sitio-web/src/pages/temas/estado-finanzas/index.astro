---
import Base from "../../../layouts/Base.astro";
import StatCard from "../../../components/ui/StatCard.astro";
import ChapterCard from "../../../components/ui/ChapterCard.astro";
import { getTema, getCapituloHref } from "../../../lib/temas";

const tema = getTema("estado-finanzas")!;

const iconos: Record<string, string> = {
  "01-estructura-estado": "🏛️",
  "02-sueldos-publicos": "💰",
  "03-impuestos": "🧾",
  "04-presupuesto": "📊",
  "05-deuda": "🏦",
  "06-capital-privado": "🌐",
  "07-eficiencia": "⚖️",
};

// Capítulos publicados hasta ahora. Vacío mientras está en investigación.
const builtSlugs = new Set<string>([]);

const chapters = tema.capitulos.map((c) => ({
  number: String(c.numero).padStart(2, "0"),
  title: c.titulo,
  description: c.descripcion,
  href: getCapituloHref(tema.slug, c.slug),
  icon: iconos[c.slug] ?? "📄",
  color: c.accentColor,
  available: builtSlugs.has(c.slug),
}));
---

<Base title="Estado y finanzas públicas">
  <section class="relative overflow-hidden mesh-gradient-hero">
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 pt-12 pb-16 sm:pt-16 sm:pb-20 md:pt-28 md:pb-32">
      <div class="flex justify-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white/80 px-3 sm:px-4 py-1.5 text-[11px] sm:text-xs font-medium text-emerald-700 shadow-sm backdrop-blur text-center">
          <span class="flex h-1.5 w-1.5 rounded-full bg-emerald-500 flex-shrink-0"></span>
          Tema 03 · Estado y finanzas públicas · En investigación
        </div>
      </div>

      <h1 class="mt-6 sm:mt-8 text-center text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.05] text-neutral-900">
        ¿Cómo se mueve<br />
        <span class="gradient-text">la plata pública?</span>
      </h1>

      <p class="mx-auto mt-5 sm:mt-6 max-w-2xl text-center text-base sm:text-lg md:text-xl text-neutral-600 leading-relaxed px-2">
        Quién maneja el Estado, cuánto cuesta operarlo, de dónde sale la plata y
        cómo se mueve dentro y fuera del país. Sin jerga, con fuentes oficiales.
      </p>

      <div class="mt-8 sm:mt-10 flex justify-center px-4 sm:px-0">
        <a href="#capitulos" class="btn-primary justify-center">
          Ver los capítulos
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <div class="mt-12 sm:mt-16 md:mt-20 grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
        <StatCard value="$502 B" label="Presupuesto General 2025" sublabel="Ley anual de presupuesto" accent="emerald" />
        <StatCard value="~250 mil" label="Servidores públicos nacionales" sublabel="DAFP, planta + provisional" accent="amber" />
        <StatCard value="~63%" label="Deuda pública / PIB" sublabel="MFMP 2025, proyectado" accent="rose" />
        <StatCard value="~20%" label="Recaudo tributario / PIB" sublabel="DIAN + tributos territoriales" accent="cyan" />
      </div>
    </div>
    <div class="absolute inset-x-0 bottom-0 h-24 sm:h-32 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
  </section>

  <section class="relative mx-auto max-w-4xl px-4 sm:px-6 py-16 sm:py-20 md:py-24">
    <div class="text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-neutral-500">
        El alcance
      </div>
      <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-neutral-900">
        Cinco preguntas que el tema responde
      </h2>
    </div>

    <div class="mt-10 sm:mt-12 grid md:grid-cols-2 gap-4 sm:gap-5">
      <div class="rounded-2xl border border-neutral-200 bg-white p-5 sm:p-6">
        <div class="text-xs font-bold uppercase tracking-wider text-emerald-700">Pregunta 1</div>
        <h3 class="mt-2 text-lg font-bold text-neutral-900">¿Qué tan grande es el Estado colombiano?</h3>
        <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
          Tres ramas, decenas de organismos autónomos, 32 departamentos y más de 1.100 municipios.
          Capítulo 1 cuenta a todos los servidores, su distribución geográfica y el tipo de
          vinculación (planta, provisional, contrato).
        </p>
      </div>
      <div class="rounded-2xl border border-neutral-200 bg-white p-5 sm:p-6">
        <div class="text-xs font-bold uppercase tracking-wider text-amber-700">Pregunta 2</div>
        <h3 class="mt-2 text-lg font-bold text-neutral-900">¿Cuánto ganan en el Estado?</h3>
        <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
          Desde el Presidente hasta el técnico operativo. Comparado con el salario mínimo,
          con la mediana del sector privado y con otros países de la OCDE. Capítulo 2
          desarma el debate de los "sueldos altos" con cifras.
        </p>
      </div>
      <div class="rounded-2xl border border-neutral-200 bg-white p-5 sm:p-6">
        <div class="text-xs font-bold uppercase tracking-wider text-cyan-700">Pregunta 3</div>
        <h3 class="mt-2 text-lg font-bold text-neutral-900">¿De dónde sale la plata?</h3>
        <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
          IVA, renta, GMF, aranceles, regalías. Quién paga qué. Cómo se compara Colombia
          con la OCDE en presión fiscal. Y por qué cada año hay una nueva reforma
          tributaria. Capítulos 3.
        </p>
      </div>
      <div class="rounded-2xl border border-neutral-200 bg-white p-5 sm:p-6">
        <div class="text-xs font-bold uppercase tracking-wider text-violet-700">Pregunta 4</div>
        <h3 class="mt-2 text-lg font-bold text-neutral-900">¿En qué se gasta?</h3>
        <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
          El Presupuesto General de la Nación, la deuda pública y la eficiencia del gasto.
          Por qué el 85% del presupuesto está comprometido por ley antes de que empiece
          el año. Capítulos 4, 5 y 7.
        </p>
      </div>
      <div class="rounded-2xl border border-neutral-200 bg-white p-5 sm:p-6 md:col-span-2">
        <div class="text-xs font-bold uppercase tracking-wider text-sky-700">Pregunta 5</div>
        <h3 class="mt-2 text-lg font-bold text-neutral-900">¿Cómo se mueve el capital privado?</h3>
        <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
          Inversión extranjera directa, remesas de migrantes, salida de capitales,
          balanza de pagos. Por qué importan para el peso, las tasas de interés y la
          economía cotidiana. Capítulo 6.
        </p>
      </div>
    </div>
  </section>

  <section id="capitulos" class="relative bg-neutral-50 border-y border-neutral-200">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20 md:py-24">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-neutral-500">
          El recorrido
        </div>
        <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-neutral-900">
          {chapters.length} capítulos en preparación
        </h2>
        <p class="mt-4 text-base sm:text-lg text-neutral-600 max-w-2xl mx-auto">
          Cada capítulo se publica cuando los datos están descargados y verificados
          contra la fuente primaria. Mientras tanto, las tarjetas muestran el alcance.
        </p>
      </div>

      <div class="mt-10 sm:mt-12 md:mt-14 grid gap-4 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {chapters.map((ch) => <ChapterCard {...ch} />)}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-16 sm:py-20 md:py-24">
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50/40 p-6 sm:p-8">
      <h3 class="text-xl sm:text-2xl font-bold text-neutral-900">Fuentes oficiales que usamos</h3>
      <p class="mt-3 text-sm sm:text-base text-neutral-700 leading-relaxed">
        Todo el contenido se verifica contra la fuente primaria. Las principales:
      </p>
      <ul class="mt-4 grid sm:grid-cols-2 gap-3 text-sm text-neutral-700">
        <li class="flex gap-2"><span class="text-emerald-600 font-bold">▸</span> <strong>DIAN</strong> — recaudo tributario nacional</li>
        <li class="flex gap-2"><span class="text-emerald-600 font-bold">▸</span> <strong>MinHacienda</strong> — PGN, MFMP, deuda pública</li>
        <li class="flex gap-2"><span class="text-emerald-600 font-bold">▸</span> <strong>DAFP</strong> — empleo público, escalas salariales</li>
        <li class="flex gap-2"><span class="text-emerald-600 font-bold">▸</span> <strong>BanRep</strong> — balanza de pagos, IED, remesas, deuda externa</li>
        <li class="flex gap-2"><span class="text-emerald-600 font-bold">▸</span> <strong>DNP</strong> — Plan Nacional de Desarrollo, inversión pública</li>
        <li class="flex gap-2"><span class="text-emerald-600 font-bold">▸</span> <strong>Contraloría</strong> — ejecución presupuestal, auditorías</li>
        <li class="flex gap-2"><span class="text-emerald-600 font-bold">▸</span> <strong>OCDE</strong> — comparación internacional (tax, gobierno)</li>
        <li class="flex gap-2"><span class="text-emerald-600 font-bold">▸</span> <strong>Transparencia Int'l</strong> — índice de percepción de corrupción</li>
      </ul>
    </div>
  </section>
</Base>
