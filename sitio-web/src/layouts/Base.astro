---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  description?: string;
  showHeader?: boolean;
}

const {
  title,
  description = "Un recorrido paso a paso por el mercado laboral colombiano: cuántos trabajan, cuántos no, quiénes son invisibles en las cifras y por qué depende de a quién le preguntes.",
  showHeader = true,
} = Astro.props;

const siteName = "Empleo Colombia";
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CO" />

    <!-- Theme -->
    <meta name="theme-color" content="#4f46e5" />
  </head>
  <body class="min-h-screen bg-white">
    {showHeader && <Header />}
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
