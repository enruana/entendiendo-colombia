---
import Base from "./Base.astro";

interface Props {
  number: string;
  title: string;
  subtitle: string;
  chapterNumber: number;
  totalChapters: number;
  prevHref?: string;
  prevTitle?: string;
  nextHref?: string;
  nextTitle?: string;
  accentColor?: "indigo" | "violet" | "pink" | "cyan" | "amber" | "emerald" | "rose" | "sky";
}

const {
  number,
  title,
  subtitle,
  chapterNumber,
  totalChapters,
  prevHref,
  prevTitle,
  nextHref,
  nextTitle,
  accentColor = "indigo",
} = Astro.props;

const progress = (chapterNumber / totalChapters) * 100;

const gradients = {
  indigo: "from-indigo-500 via-indigo-600 to-violet-600",
  violet: "from-violet-500 via-violet-600 to-purple-600",
  pink: "from-pink-500 via-pink-600 to-rose-600",
  cyan: "from-cyan-500 via-cyan-600 to-blue-600",
  amber: "from-amber-500 via-amber-600 to-orange-600",
  emerald: "from-emerald-500 via-emerald-600 to-teal-600",
  rose: "from-rose-500 via-rose-600 to-pink-600",
  sky: "from-sky-500 via-sky-600 to-indigo-600",
};

const badges = {
  indigo: "bg-indigo-50 text-indigo-700 border-indigo-200",
  violet: "bg-violet-50 text-violet-700 border-violet-200",
  pink: "bg-pink-50 text-pink-700 border-pink-200",
  cyan: "bg-cyan-50 text-cyan-700 border-cyan-200",
  amber: "bg-amber-50 text-amber-700 border-amber-200",
  emerald: "bg-emerald-50 text-emerald-700 border-emerald-200",
  rose: "bg-rose-50 text-rose-700 border-rose-200",
  sky: "bg-sky-50 text-sky-700 border-sky-200",
};
---

<Base title={title}>
  <!-- Progress bar sticky -->
  <div class="sticky top-16 z-40 h-1 bg-neutral-100">
    <div
      class:list={["h-full bg-gradient-to-r transition-all duration-500", gradients[accentColor]]}
      style={`width: ${progress}%`}
    ></div>
  </div>

  <!-- Chapter header -->
  <header class="relative overflow-hidden border-b border-neutral-200">
    <div class="absolute inset-0 mesh-gradient-hero opacity-60"></div>
    <div class="relative mx-auto max-w-4xl px-6 pt-16 pb-14">
      <div class="flex items-center gap-3">
        <div class:list={["inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-wider", badges[accentColor]]}>
          Capitulo {number}
        </div>
        <div class="text-xs text-neutral-500">
          {chapterNumber} de {totalChapters}
        </div>
      </div>

      <h1 class="mt-5 text-4xl md:text-5xl font-extrabold tracking-tighter text-neutral-900 leading-[1.1]">
        {title}
      </h1>
      <p class="mt-4 text-xl text-neutral-600 leading-relaxed max-w-2xl">
        {subtitle}
      </p>
    </div>
  </header>

  <!-- Chapter content -->
  <article class="relative mx-auto max-w-4xl px-6 py-14">
    <div class="prose-custom">
      <slot />
    </div>
  </article>

  <!-- Chapter navigation -->
  <nav class="border-t border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-4xl px-6 py-10">
      <div class="grid grid-cols-2 gap-4">
        {prevHref ? (
          <a href={prevHref} class="group rounded-xl border border-neutral-200 bg-white p-5 transition-all hover:border-neutral-300 hover:shadow-sm hover:-translate-y-0.5">
            <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-neutral-500">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
              </svg>
              Capitulo anterior
            </div>
            <div class="mt-2 text-base font-bold text-neutral-900 group-hover:text-indigo-700 transition-colors">
              {prevTitle}
            </div>
          </a>
        ) : <div></div>}

        {nextHref ? (
          <a href={nextHref} class="group rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50/50 to-violet-50/30 p-5 transition-all hover:border-indigo-300 hover:shadow-md hover:-translate-y-0.5 text-right">
            <div class="flex items-center justify-end gap-2 text-xs font-semibold uppercase tracking-wider text-indigo-600">
              Siguiente capitulo
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
            <div class="mt-2 text-base font-bold text-neutral-900 group-hover:text-indigo-700 transition-colors">
              {nextTitle}
            </div>
          </a>
        ) : (
          <a href="/" class="group rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50/50 to-violet-50/30 p-5 transition-all hover:border-indigo-300 text-right">
            <div class="text-xs font-semibold uppercase tracking-wider text-indigo-600">
              Volver al inicio
            </div>
            <div class="mt-2 text-base font-bold text-neutral-900 group-hover:text-indigo-700">
              Has terminado el recorrido
            </div>
          </a>
        )}
      </div>
    </div>
  </nav>
</Base>
