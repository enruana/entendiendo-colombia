---
interface Props {
  type?: "info" | "warning" | "source" | "tip" | "key";
  title?: string;
}

const { type = "info", title } = Astro.props;

const styles = {
  info: {
    bg: "bg-indigo-50/60",
    border: "border-indigo-200",
    iconBg: "bg-indigo-100",
    iconColor: "text-indigo-600",
    titleColor: "text-indigo-900",
    textColor: "text-indigo-900/80",
    defaultTitle: "Nota",
    icon: `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" /></svg>`,
  },
  warning: {
    bg: "bg-amber-50/60",
    border: "border-amber-200",
    iconBg: "bg-amber-100",
    iconColor: "text-amber-600",
    titleColor: "text-amber-900",
    textColor: "text-amber-900/80",
    defaultTitle: "Atencion",
    icon: `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>`,
  },
  source: {
    bg: "bg-neutral-50",
    border: "border-neutral-200",
    iconBg: "bg-neutral-200",
    iconColor: "text-neutral-700",
    titleColor: "text-neutral-900",
    textColor: "text-neutral-700",
    defaultTitle: "Fuente",
    icon: `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>`,
  },
  tip: {
    bg: "bg-emerald-50/60",
    border: "border-emerald-200",
    iconBg: "bg-emerald-100",
    iconColor: "text-emerald-600",
    titleColor: "text-emerald-900",
    textColor: "text-emerald-900/80",
    defaultTitle: "Tip",
    icon: `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
  },
  key: {
    bg: "bg-gradient-to-br from-indigo-50/70 to-violet-50/50",
    border: "border-indigo-200",
    iconBg: "bg-gradient-to-br from-indigo-500 to-violet-500",
    iconColor: "text-white",
    titleColor: "text-indigo-900",
    textColor: "text-indigo-900/80",
    defaultTitle: "Dato clave",
    icon: `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
  },
};

const s = styles[type];
const displayTitle = title || s.defaultTitle;
---

<div class:list={["my-8 rounded-xl border p-5", s.bg, s.border]}>
  <div class="flex items-start gap-3">
    <div class:list={["flex-shrink-0 flex h-8 w-8 items-center justify-center rounded-lg", s.iconBg, s.iconColor]}>
      <Fragment set:html={s.icon} />
    </div>
    <div class="flex-1 min-w-0">
      <div class:list={["text-sm font-bold", s.titleColor]}>
        {displayTitle}
      </div>
      <div class:list={["mt-1.5 text-sm leading-relaxed", s.textColor]}>
        <slot />
      </div>
    </div>
  </div>
</div>
