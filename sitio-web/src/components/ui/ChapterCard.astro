---
interface Props {
  number: string;
  title: string;
  description: string;
  href: string;
  icon: string;
  color: "indigo" | "violet" | "pink" | "cyan" | "amber" | "emerald" | "rose" | "sky";
  available?: boolean;
}

const { number, title, description, href, icon, color, available = true } = Astro.props;

const gradients = {
  indigo: "from-indigo-500 to-indigo-600",
  violet: "from-violet-500 to-violet-600",
  pink: "from-pink-500 to-pink-600",
  cyan: "from-cyan-500 to-cyan-600",
  amber: "from-amber-500 to-amber-600",
  emerald: "from-emerald-500 to-emerald-600",
  rose: "from-rose-500 to-rose-600",
  sky: "from-sky-500 to-sky-600",
};

const bgTints = {
  indigo: "group-hover:bg-indigo-50/40",
  violet: "group-hover:bg-violet-50/40",
  pink: "group-hover:bg-pink-50/40",
  cyan: "group-hover:bg-cyan-50/40",
  amber: "group-hover:bg-amber-50/40",
  emerald: "group-hover:bg-emerald-50/40",
  rose: "group-hover:bg-rose-50/40",
  sky: "group-hover:bg-sky-50/40",
};
---

<a
  href={available ? href : "#"}
  class:list={[
    "group relative flex flex-col gap-4 rounded-2xl border border-neutral-200 bg-white p-6 transition-all",
    available
      ? "hover:border-neutral-300 hover:shadow-lg hover:-translate-y-1 cursor-pointer"
      : "opacity-60 cursor-not-allowed",
    bgTints[color]
  ]}
>
  <div class="flex items-start justify-between gap-4">
    <div class:list={[
      "flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br shadow-sm",
      gradients[color]
    ]}>
      <span class="text-lg" set:html={icon}></span>
    </div>
    <div class="text-xs font-mono font-semibold uppercase tracking-wider text-neutral-400">
      {number}
    </div>
  </div>

  <div>
    <h3 class="text-lg font-bold text-neutral-900 leading-snug">{title}</h3>
    <p class="mt-2 text-sm text-neutral-600 leading-relaxed">{description}</p>
  </div>

  {available && (
    <div class="flex items-center gap-1 text-sm font-semibold text-indigo-600 group-hover:gap-2 transition-all">
      Explorar
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </div>
  )}

  {!available && (
    <div class="text-xs font-semibold uppercase tracking-wider text-neutral-400">
      Proximamente
    </div>
  )}
</a>
