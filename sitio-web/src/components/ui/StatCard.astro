---
interface Props {
  value: string;
  label: string;
  sublabel?: string;
  accent?: "indigo" | "violet" | "pink" | "cyan" | "amber" | "emerald";
  highlight?: boolean;
}

const { value, label, sublabel, accent = "indigo", highlight = false } = Astro.props;

const accentClasses = {
  indigo: "from-indigo-500 to-indigo-600",
  violet: "from-violet-500 to-violet-600",
  pink: "from-pink-500 to-pink-600",
  cyan: "from-cyan-500 to-cyan-600",
  amber: "from-amber-500 to-amber-600",
  emerald: "from-emerald-500 to-emerald-600",
};
---

<div class:list={[
  "rounded-xl border p-5 transition-all",
  highlight
    ? "border-indigo-200 bg-gradient-to-br from-indigo-50/50 to-violet-50/30 shadow-sm"
    : "border-neutral-200 bg-white hover:border-neutral-300 hover:shadow-sm"
]}>
  <div class:list={[
    "inline-flex h-1 w-12 rounded-full bg-gradient-to-r",
    accentClasses[accent]
  ]}></div>
  <div class="mt-3 text-3xl font-extrabold tracking-tight text-neutral-900 font-mono">
    {value}
  </div>
  <div class="mt-1 text-sm font-medium text-neutral-900">{label}</div>
  {sublabel && <div class="mt-0.5 text-xs text-neutral-500">{sublabel}</div>}
</div>
