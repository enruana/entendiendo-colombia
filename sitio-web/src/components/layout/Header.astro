---
const navItems = [
  { label: "Empezar", href: "/empezar-aqui" },
  { label: "Capitulos", href: "/#capitulos" },
  { label: "Datos", href: "/datos" },
  { label: "Glosario", href: "/glosario" },
  { label: "Fuentes", href: "/fuentes" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-neutral-200/60 bg-white/80 backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2 group">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-indigo-600 via-violet-600 to-pink-500 shadow-sm transition-transform group-hover:scale-105">
        <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
        </svg>
      </div>
      <span class="text-base font-bold tracking-tight text-neutral-900">Empleo Colombia</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-md px-3 py-1.5 text-sm font-medium transition-colors",
            currentPath === item.href
              ? "text-indigo-600"
              : "text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100"
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a href="/empezar-aqui" class="btn-primary !py-2 !px-4 text-sm hidden sm:inline-flex">
      Comenzar recorrido
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </a>
  </div>
</header>
